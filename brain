// ============================================================
// ENCODER INTERRUPT SERVICE ROUTINES
// ============================================================
void IRAM_ATTR enc_m6_A_ISR() {
    bool a = digitalRead(ENC_A_M6);
    bool b = digitalRead(ENC_B_M6);
    if (a == b) enc_count_m6++;
    else        enc_count_m6--;
}

void IRAM_ATTR enc_m7_A_ISR() {
    bool a = digitalRead(ENC_A_M7);
    bool b = digitalRead(ENC_B_M7);
    if (a == b) enc_count_m7++;
    else        enc_count_m7--;
}

// ============================================================
// MOTOR CONTROL FUNCTIONS
// ============================================================

// Front motor pair (L298N simple control)
void setFrontMotors(int speed) {
    // speed: -255 to 255
    front_motor_speed = constrain(speed, -255, 255);
    if (front_motor_speed > 0) {
        digitalWrite(MOTOR_FRONT_IN1, HIGH);
        digitalWrite(MOTOR_FRONT_IN2, LOW);
        ledcWrite(PWM_CH_FRONT, front_motor_speed);
    } else if (front_motor_speed < 0) {
        digitalWrite(MOTOR_FRONT_IN1, LOW);
        digitalWrite(MOTOR_FRONT_IN2, HIGH);
        ledcWrite(PWM_CH_FRONT, -front_motor_speed);
    } else {
        digitalWrite(MOTOR_FRONT_IN1, LOW);
        digitalWrite(MOTOR_FRONT_IN2, LOW);
        ledcWrite(PWM_CH_FRONT, 0);
    }
}

// Motor 6 (Pololu 37D, VNH5019 style)
void setMotor6(int speed) {
    speed = constrain(speed, -255, 255);
    actual_speed_m6 = speed;
    if (speed > 0) {
        digitalWrite(DIR_A_M6, HIGH);
        digitalWrite(DIR_B_M6, LOW);
        ledcWrite(PWM_CH_M6, speed);
    } else if (speed < 0) {
        digitalWrite(DIR_A_M6, LOW);
        digitalWrite(DIR_B_M6, HIGH);
        ledcWrite(PWM_CH_M6, -speed);
    } else {
        digitalWrite(DIR_A_M6, LOW);
        digitalWrite(DIR_B_M6, LOW);
        ledcWrite(PWM_CH_M6, 0);
    }
}

// Motor 7 (Pololu 37D, L298N style)
void setMotor7(int speed) {
    speed = constrain(speed, -255, 255);
    actual_speed_m7 = speed;
    if (speed > 0) {
        digitalWrite(MOTOR_M7_IN1, HIGH);
        digitalWrite(MOTOR_M7_IN2, LOW);
        ledcWrite(PWM_CH_M7, speed);
    } else if (speed < 0) {
        digitalWrite(MOTOR_M7_IN1, LOW);
        digitalWrite(MOTOR_M7_IN2, HIGH);
        ledcWrite(PWM_CH_M7, -speed);
    } else {
        digitalWrite(MOTOR_M7_IN1, LOW);
        digitalWrite(MOTOR_M7_IN2, LOW);
        ledcWrite(PWM_CH_M7, 0);
    }
}

// All motors stop
void stopAllMotors() {
    setFrontMotors(0);
    setMotor6(0);
    setMotor7(0);
    target_speed_m6 = 0;
    target_speed_m7 = 0;
}

// Drive all four wheels
void driveRover(int leftSpeed, int rightSpeed) {
    // leftSpeed / rightSpeed: -255 to 255
    // Front motors mirror rear
    int avgSpeed = (leftSpeed + rightSpeed) / 2;
    setFrontMotors(avgSpeed);  // Front pair as average (or split if wired separately)
    setMotor6(leftSpeed);      // Rear-left
    setMotor7(rightSpeed);     // Rear-right

    target_speed_m6 = leftSpeed;
    target_speed_m7 = rightSpeed;
}

// High-level motion commands
void moveForward(float speedFactor = 1.0f) {
    int spd = (int)(255.0f * constrain(speedFactor, 0.0f, 1.0f));
    driveRover(spd, spd);
    telemetry.current_cmd = CMD_FORWARD;
}

void moveBackward(float speedFactor = 1.0f) {
    int spd = (int)(255.0f * constrain(speedFactor, 0.0f, 1.0f));
    driveRover(-spd, -spd);
    telemetry.current_cmd = CMD_BACKWARD;
}

void turnLeft(float speedFactor = 1.0f) {
    // Differential: right faster, left slower
    int spd = (int)(255.0f * constrain(speedFactor, 0.0f, 1.0f));
    driveRover(spd / 2, spd);
    telemetry.current_cmd = CMD_TURN_LEFT;
}

void turnRight(float speedFactor = 1.0f) {
    int spd = (int)(255.0f * constrain(speedFactor, 0.0f, 1.0f));
    driveRover(spd, spd / 2);
    telemetry.current_cmd = CMD_TURN_RIGHT;
}

void spinLeft(float speedFactor = 1.0f) {
    int spd = (int)(255.0f * constrain(speedFactor, 0.0f, 1.0f));
    driveRover(-spd, spd);
    telemetry.current_cmd = CMD_SPIN_LEFT;
}

void spinRight(float speedFactor = 1.0f) {
    int spd = (int)(255.0f * constrain(speedFactor, 0.0f, 1.0f));
    driveRover(spd, -spd);
    telemetry.current_cmd = CMD_SPIN_RIGHT;
}

